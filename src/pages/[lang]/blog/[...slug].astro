---
import { fetchPosts, blogPostRobots, useTranslations } from '~/utils/blog';
import { LANGUAGES } from '~/i18n/utils';
import merge from 'lodash.merge';
import Layout from '~/layouts/PageLayout.astro';
import SinglePost from '~/components/blog/SinglePost.astro';
import ToBlogLink from '~/components/blog/ToBlogLink.astro';
import RelatedPosts from '~/components/blog/RelatedPosts.astro';
import Notice from '~/components/ui/Notice.astro';
import { getCanonical, getPermalink } from '~/utils/permalinks';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await fetchPosts();
  const locales = Object.keys(LANGUAGES);
  const allSlugs = [...new Set(posts.map(p => p.slug))];
  return locales.flatMap((lang) => {
    return allSlugs.map((slug) => {
      let post = posts.find((p) => p.slug === slug && p.lang === lang);
      let isFallback = false;
      if (!post) {
        post = posts.find((p) => p.slug === slug);
        isFallback = true;
      }
      if (!post) return null;
      return {
        params: { lang, slug },
        props: { post, isFallback },
      };
    }).filter(Boolean);
  });
}

const { post, isFallback } = Astro.props;
const { lang } = Astro.params;
const t = useTranslations(lang);
const url = getCanonical(getPermalink(post.permalink, 'post', lang));
const metadata = merge(
  {
    title: post.title,
    description: post.excerpt,
    robots: {
      index: !isFallback && blogPostRobots?.index,
      follow: blogPostRobots?.follow,
    },
    openGraph: { type: 'article', image: post.image },
  },
  { ...(post?.metadata ?? {}) }
);
---

<Layout metadata={metadata}>
  {isFallback && (
    <Notice
      title={t('fallbacks.post.title')}
      class="max-w-3xl px-4 sm:px-6"
    >
      {t('fallbacks.post.desc')}
    </Notice>
  )}
  <SinglePost post={post} url={url}>
    <post.Content />
  </SinglePost>
  <ToBlogLink />
  <RelatedPosts post={post} />
</Layout>
