---
import { Icon } from 'astro-icon/components';
import { twMerge } from 'tailwind-merge';

interface Props {
  title?: string;
  icon?: string;
  class?: string;
}

const {
  title,
  icon = 'tabler:info-circle',
  class: className,
} = Astro.props;

const classes = twMerge(
  'container mx-auto max-w-4xl mt-8 sm:mt-16',
  'intersect-once intersect-quarter',
  'motion-safe:md:opacity-0 motion-safe:md:translate-y-8',
  'motion-safe:md:transition-all motion-safe:md:duration-700 motion-safe:md:ease-out',
  'motion-safe:md:intersect:opacity-100 motion-safe:md:intersect:translate-y-0',
  className
);
---

<div class={classes}>
  <div
    class="notice-glass flex items-start gap-3 px-5 py-4 rounded-xl
           bg-gradient-to-br from-white/90 to-gray-50/80
           dark:from-slate-800/80 dark:to-slate-900/60
           border border-white/60 dark:border-white/10"
    role="note"
  >
    <Icon name={icon} class="w-5 h-5 flex-shrink-0 mt-0.5 text-gray-400 dark:text-slate-500" />
    <div>
      {title && (
        <p class="font-semibold text-sm text-gray-700 dark:text-slate-300 mb-0.5">
          {title}
        </p>
      )}
      <div class="text-sm text-muted dark:text-slate-400 leading-relaxed">
        <slot />
      </div>
    </div>
  </div>
</div>

<style>
  .notice-glass {
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 2px solid rgb(255 255 255 / 0.95);
    box-shadow:
      0 8px 32px rgb(0 0 0 / 0.08),
      0 2px 8px rgb(0 0 0 / 0.04),
      inset 0 1px 0 rgb(255 255 255 / 0.9);
  }

  :global(.dark) .notice-glass {
    border-top: 2px solid rgb(255 255 255 / 0.12);
    box-shadow:
      0 8px 32px rgb(0 0 0 / 0.4),
      0 2px 8px rgb(0 0 0 / 0.2),
      inset 0 1px 0 rgb(255 255 255 / 0.08);
  }
</style>
