---
import { Icon } from 'astro-icon/components';
import { twMerge } from 'tailwind-merge';

interface Props {
  title?: string;
  icon?: string;
  class?: string;
}

const {
  title,
  icon = 'tabler:info-circle',
  class: className,
} = Astro.props;

const classes = twMerge(
  'container mx-auto max-w-4xl mt-8 sm:mt-16',
  'intersect-once intersect-quarter',
  'motion-safe:md:opacity-0 motion-safe:md:translate-y-8',
  'motion-safe:md:transition-all motion-safe:md:duration-700 motion-safe:md:ease-out',
  'motion-safe:md:intersect:opacity-100 motion-safe:md:intersect:translate-y-0',
  className
);
---

<div class={classes}>
  <div
    class="flex items-start gap-4 px-5 py-4 rounded-lg
           bg-gray-50 dark:bg-slate-800
           border border-gray-200 dark:border-slate-700
           border-l-4 border-l-primary"
    role="note"
  >
    <Icon name={icon} class="w-5 h-5 flex-shrink-0 mt-0.5 text-primary" />
    <div>
      {title && (
        <p class="font-semibold text-sm text-gray-900 dark:text-slate-100 mb-0.5">
          {title}
        </p>
      )}
      <div class="text-sm text-muted dark:text-slate-400 leading-relaxed">
        <slot />
      </div>
    </div>
  </div>
</div>
