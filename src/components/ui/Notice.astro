---
import { Icon } from 'astro-icon/components';
import { twMerge } from 'tailwind-merge';

interface Props {
  title?: string;
  icon?: string;
  class?: string;
}

const {
  title,
  icon = 'tabler:info-circle',
  class: className,
} = Astro.props;

const classes = twMerge(
  'container mx-auto max-w-4xl mt-8 sm:mt-16',
  'intersect-once intersect-quarter',
  'motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade',
  className
);
---

<div class={classes}>
<div
  class="flex items-start gap-4 p-5 rounded-xl
         bg-white/70 dark:bg-slate-800/50
         backdrop-blur-sm
         border border-white/80 dark:border-slate-700/50
         shadow-md shadow-blue-100/50 dark:shadow-none
         ring-1 ring-blue-200/50 dark:ring-blue-800/30"
  role="alert"
>
    <Icon name={icon} class="w-6 h-6 flex-shrink-0 mt-0.5 text-blue-500" />

    <div>
      {title && (
        <h3 class="mb-1 text-sm font-medium uppercase tracking-wide text-blue-800 dark:text-blue-200">
          {title}
        </h3>
      )}
      <div class="text-sm leading-relaxed text-blue-800 dark:text-blue-200">
        <slot />
      </div>
    </div>
  </div>
</div>
