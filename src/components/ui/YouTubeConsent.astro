---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<div class="relative aspect-video w-full rounded-xl overflow-hidden bg-slate-900 shadow-xl">
  <!-- Hintergrund -->
  <div class="absolute inset-0 bg-gradient-to-br from-slate-800 to-slate-950" />
  <div class="absolute inset-0 opacity-10"
    style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 24px 24px;" />

  <!-- Placeholder -->
  <div id={`yt-placeholder-${id}`}
    class="absolute inset-0 flex flex-col items-center justify-center gap-5 p-6 text-center">

    <!-- Play + Lock Icon -->
    <div class="relative">
      <div class="w-16 h-16 rounded-full bg-white/10 border border-white/20 flex items-center justify-center backdrop-blur-sm">
        <svg class="w-6 h-6 text-white/50 ml-1" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
      </div>
      <div class="absolute -bottom-1 -right-1 w-6 h-6 rounded-full bg-slate-700 border border-slate-600 flex items-center justify-center">
        <svg class="w-3 h-3 text-gray-300" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>
        </svg>
      </div>
    </div>

    <div class="flex flex-col gap-1">
      <p class="text-white/90 text-sm font-medium">Video nicht verfügbar</p>
      <p class="text-white/50 text-xs max-w-xs leading-relaxed">
        Für die Wiedergabe sind funktionale Cookies erforderlich.
      </p>
    </div>

    <button
      data-cc="show-preferencesModal"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 hover:bg-white/20 border border-white/20 text-white/90 text-xs font-medium transition-colors cursor-pointer backdrop-blur-sm"
    >
      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
        <path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
      </svg>
      Cookie-Einstellungen
    </button>
  </div>

  <!-- Embed -->
  <div id={`yt-embed-${id}`} class="absolute inset-0 hidden" />
</div>

<script define:vars={{ id, title }}>
  function loadVideo() {
    const placeholder = document.getElementById(`yt-placeholder-${id}`);
    const embed = document.getElementById(`yt-embed-${id}`);
    if (!embed || embed.dataset.loaded) return;

    embed.innerHTML = `<iframe
      src="https://www.youtube-nocookie.com/embed/${id}"
      title="${title}"
      style="width:100%;height:100%;position:absolute;top:0;left:0;"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>`;
    embed.dataset.loaded = 'true';
    embed.classList.remove('hidden');
    placeholder?.classList.add('hidden');
  }

  window.addEventListener('cc:onConsent', (e) => {
    if (e.detail?.cookie?.categories?.includes('functionality')) {
      loadVideo();
    }
  });

  window.addEventListener('cc:onChange', (e) => {
    if (e.detail?.cookie?.categories?.includes('functionality')) {
      loadVideo();
    }
  });
</script>
