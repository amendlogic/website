---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<div class="relative aspect-video w-full rounded-lg overflow-hidden bg-gray-100 dark:bg-slate-800">

  <div
    id={`yt-placeholder-${id}`}
    class="absolute inset-0 flex flex-col items-center justify-center gap-4 p-6 text-center"
  >
    <p class="text-sm text-gray-600 dark:text-gray-400">
      Dieses Video wird erst nach Einwilligung in funktionale Cookies geladen.
    </p>
    <button
      id={`yt-btn-${id}`}
      class="text-sm underline text-primary cursor-pointer"
    >
      Cookie-Einstellungen öffnen
    </button>
  </div>

  <div id={`yt-embed-${id}`} class="absolute inset-0 hidden"></div>

</div>

<script define:vars={{ id, title }}>
  console.log('Script geladen für Video:', id);

  document.addEventListener('DOMContentLoaded', () => {
    console.log('DOMContentLoaded');
    console.log('CookieConsent verfügbar:', typeof window.CookieConsent);
    
    document.getElementById(`yt-btn-${id}`)?.addEventListener('click', () => {
      console.log('Button geklickt');
      console.log('CookieConsent:', window.CookieConsent);
      window.CookieConsent?.showPreferences();
    });

    loadVideo();
  });

  window.addEventListener('cc:onFirstConsent', (e) => {
    console.log('cc:onFirstConsent gefeuert', e);
    loadVideo();
  });

  window.addEventListener('cc:onChange', (e) => {
    console.log('cc:onChange gefeuert', e);
    loadVideo();
  });

  // Alle cc: Events abfangen
  ['cc:onConsent', 'cc:onFirstConsent', 'cc:onChange', 'cc:onLoad'].forEach(evt => {
    window.addEventListener(evt, (e) => console.log(`Event: ${evt}`, e));
  });

  function loadVideo() {
    console.log('loadVideo aufgerufen');
    console.log('CookieConsent:', typeof window.CookieConsent);
    if (typeof window.CookieConsent !== 'undefined') {
      console.log('acceptedCategory functionality:', window.CookieConsent.acceptedCategory('functionality'));
    }
  }
</script>
