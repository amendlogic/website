---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<div class="relative aspect-video w-full rounded-lg overflow-hidden bg-gray-100 dark:bg-slate-800">

  <div
    id={`yt-placeholder-${id}`}
    class="absolute inset-0 flex flex-col items-center justify-center gap-4 p-6 text-center"
  >
    <p class="text-sm text-gray-600 dark:text-gray-400">
      Dieses Video wird erst nach Einwilligung in funktionale Cookies geladen.
    </p>
    <button
      data-cc="show-preferencesModal"
      class="text-sm underline text-primary cursor-pointer"
    >
      Cookie-Einstellungen öffnen
    </button>
  </div>

  <div id={`yt-embed-${id}`} class="absolute inset-0 hidden"></div>

</div>

<script define:vars={{ id, title }}>
  function loadVideo() {
    const placeholder = document.getElementById(`yt-placeholder-${id}`);
    const embed = document.getElementById(`yt-embed-${id}`);
    if (!embed || embed.dataset.loaded) return;

    embed.innerHTML = `<iframe
      src="https://www.youtube-nocookie.com/embed/${id}"
      title="${title}"
      style="width:100%;height:100%;position:absolute;top:0;left:0;"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>`;
    embed.dataset.loaded = 'true';
    embed.classList.remove('hidden');
    placeholder?.classList.add('hidden');
  }

  window.addEventListener('cc:onConsent', (e) => {
    if (e.detail?.cookie?.categories?.includes('functionality')) {
      loadVideo();
    }
  });

  window.addEventListener('cc:onChange', (e) => {
    if (e.detail?.cookie?.categories?.includes('functionality')) {
      loadVideo();
    }
  });
</script>
