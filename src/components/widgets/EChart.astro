---
// src/components/widgets/EChart.astro
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Button from '~/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
import { parseCsvData, getBaseChartOptions, calculateTradeStats } from '~/lib/chart-data';
import { useTranslations } from '~/i18n/utils';

export interface Props {
  title?: string;
  subtitle?: string;
  tagline?: string;
  icon?: string;
  csvPath?: string;
  initialCapital?: number;
  callToAction?: Record<string, any>;
  symbol?: string;
  riskPerTrade?: string;
  showStats?: boolean;
  options?: Record<string, any>;
  id?: string;
  height?: string | number;
  locale?: string;
  isDark?: boolean;
  isAfterContent?: boolean;
  classes?: { container?: string };
  bg?: string;
}

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  icon = 'tabler:info-square',
  callToAction,
  symbol,
  riskPerTrade,
  showStats = true,
  options: userOptions = {},
  initialCapital = 300,
  csvPath,
  height = '350px',
  isAfterContent = false,
  id,
  locale = Astro.currentLocale || 'de',
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

// Eindeutige IDs für Wrapper + Chart + JSON
const uid = crypto.randomUUID().slice(0, 7);
const wrapperId = id ?? `widget-${uid}`;
const chartId = `chart-${uid}`;
const dataId = `data-${uid}`;

const { lang } = Astro.params;
const t = useTranslations(lang);

// Server Side Parsing
const parsedData  = await parseCsvData(csvPath, initialCapital);
const baseOptions = getBaseChartOptions(parsedData);
const stats       = calculateTradeStats(parsedData?.trades ?? null); // ← neu

const fmtCurrency = (n) =>
  new Intl.NumberFormat(locale, { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(n);
const fmtPct = (n) => `${(n * 100).toFixed(1)} %`;
const fmtNum = (n) => (Number.isFinite(n) ? n.toFixed(2) : '∞');

const dateFrom = parsedData?.trades?.at(0)?.timestamp  ?? null;
const dateTo   = parsedData?.trades?.at(-1)?.timestamp ?? null;
const fmtDate  = (d) => d ? new Intl.DateTimeFormat(locale, { month: 'short', year: 'numeric' }).format(new Date(d)) : '—';
---

<WidgetWrapper
  id={wrapperId}
  isDark={isDark}
  containerClass={`max-w-6xl mx-auto ${isAfterContent ? 'pt-0 md:pt-0 lg:pt-0' : ''} ${classes?.container ?? ''}`}
  bg={bg}
>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />

<!-- ── Glow Shell: nur im Dark Mode aktiv ── -->
<div class="rounded-2xl p-px
  bg-slate-200 dark:bg-gradient-to-br dark:from-primary-600/30 dark:via-secondary-600/50 dark:to-primary-600/30
  shadow-lg dark:shadow-primary-900/40 dark:[box-shadow:0_0_0_1px_theme(colors.primary.700/30),0_0_60px_theme(colors.primary.900/30),0_0_120px_theme(colors.secondary.900/20),0_32px_64px_theme(colors.slate.950/60)]
  echart-shell">

  <div class="rounded-2xl overflow-hidden
    bg-white dark:bg-slate-950">

    <!-- Aurora blobs — nur dark mode sichtbar -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0 hidden dark:block" aria-hidden="true">
      <div class="echart-blob-a absolute rounded-full opacity-[0.15]
        w-[55%] h-[55%] -top-[15%] -left-[5%]
        bg-primary-600 blur-[80px]" />
      <div class="echart-blob-b absolute rounded-full opacity-[0.12]
        w-[45%] h-[45%] -bottom-[15%] -right-[5%]
        bg-secondary-700 blur-[80px]" />
      <div class="echart-blob-a absolute rounded-full opacity-[0.06]
        w-[25%] h-[25%] top-[35%] left-[45%]
        bg-emerald-500 blur-[60px] [animation-direction:reverse] [animation-duration:12s]" />
    </div>

    <!-- Dot grid -->
    <div class="absolute inset-0 z-0 pointer-events-none
      opacity-[0.04] dark:opacity-[0.07]"
      style="background-image:radial-gradient(circle,currentColor 1px,transparent 1px);background-size:24px 24px;"
      aria-hidden="true" />

    <!-- Content -->
    <div class="relative z-10">

      <!-- ── Header ── -->
      <div class="flex items-center gap-2.5 px-5 py-3 border-b border-slate-200 dark:border-slate-800">
        <div class="w-2 h-2 rounded-full shrink-0 echart-dot
          bg-primary-500 dark:shadow-[0_0_10px_theme(colors.primary.500/80)]" />
        <span class="text-[11px] font-bold tracking-[0.1em] uppercase
          text-slate-500 dark:text-slate-400">
          AmendLogic · Performance
        </span>
        <span class="ml-auto text-[9px] font-bold tracking-[0.08em] uppercase px-2.5 py-1 rounded-full
          bg-primary-50 text-primary-600 border border-primary-200
          dark:bg-primary-950/60 dark:text-primary-400 dark:border-primary-800/60">
          Backtest
        </span>
      </div>

      <!-- ── Config Cells ── -->
      {(symbol || riskPerTrade) && (
        <>
          <div class="flex flex-wrap gap-px bg-slate-100 dark:bg-slate-800/60">

            {symbol && (
              <div class="relative flex flex-col justify-between gap-3 px-4 py-3.5 overflow-hidden
                    bg-white dark:bg-slate-950/90
                    flex-grow basis-[calc(50%-1px)] sm:basis-[calc(33.333%-1px)] lg:basis-[calc(20%-1px)]">
                <div class="absolute left-0 top-3 bottom-3 w-0.5 rounded-full
                  bg-primary-400 dark:bg-primary-500 dark:shadow-[0_0_6px_theme(colors.primary.500/60)]" />
                <div class="flex items-center justify-between pl-3">
                  <span class="text-[10px] font-semibold tracking-widest uppercase text-slate-400 dark:text-slate-500">
                    {t('echart.symbol')}
                  </span>
                  <Icon name="tabler:currency-bitcoin" class="w-3.5 h-3.5 text-slate-300 dark:text-slate-600" />
                </div>
                <span class="text-lg font-bold tabular-nums leading-none pl-3 text-slate-800 dark:text-slate-100">
                  {symbol}
                </span>
              </div>
            )}

            {(dateFrom && dateTo) && (
              <div class="relative flex flex-col justify-between gap-3 px-4 py-3.5 overflow-hidden
                    bg-white dark:bg-slate-950/90
                    flex-grow basis-[calc(50%-1px)] sm:basis-[calc(33.333%-1px)] lg:basis-[calc(40%-1px)]">
                <div class="absolute left-0 top-3 bottom-3 w-0.5 rounded-full
                  bg-primary-400 dark:bg-primary-500 dark:shadow-[0_0_6px_theme(colors.primary.500/60)]" />
                <div class="flex items-center justify-between pl-3">
                  <span class="text-[10px] font-semibold tracking-widest uppercase text-slate-400 dark:text-slate-500">
                    {t('echart.period')}
                  </span>
                  <Icon name="tabler:calendar-stats" class="w-3.5 h-3.5 text-slate-300 dark:text-slate-600" />
                </div>
                <span class="text-lg font-bold tabular-nums leading-none pl-3 text-slate-800 dark:text-slate-100">
                  {fmtDate(dateFrom)} – {fmtDate(dateTo)}
                </span>
              </div>
            )}

            {initialCapital && (
              <div class="relative flex flex-col justify-between gap-3 px-4 py-3.5 overflow-hidden
                    bg-white dark:bg-slate-950/90
                    flex-grow basis-[calc(50%-1px)] sm:basis-[calc(33.333%-1px)] lg:basis-[calc(20%-1px)]">
                <div class="absolute left-0 top-3 bottom-3 w-0.5 rounded-full
                  bg-primary-400 dark:bg-primary-500 dark:shadow-[0_0_6px_theme(colors.primary.500/60)]" />
                <div class="flex items-center justify-between pl-3">
                  <span class="text-[10px] font-semibold tracking-widest uppercase text-slate-400 dark:text-slate-500">
                    {t('echart.initialCapital')}
                  </span>
                  <Icon name="tabler:wallet" class="w-3.5 h-3.5 text-slate-300 dark:text-slate-600" />
                </div>
                <span class="text-lg font-bold tabular-nums leading-none pl-3 text-slate-800 dark:text-slate-100">
                  {fmtCurrency(initialCapital)}
                </span>
              </div>
            )}

            {riskPerTrade && (
              <div class="relative flex flex-col justify-between gap-3 px-4 py-3.5 overflow-hidden
                    bg-white dark:bg-slate-950/90
                    flex-grow basis-[calc(50%-1px)] sm:basis-[calc(33.333%-1px)] lg:basis-[calc(20%-1px)]">
                <div class="absolute left-0 top-3 bottom-3 w-0.5 rounded-full
                  bg-amber-400 dark:shadow-[0_0_8px_theme(colors.amber.400/60)]" />
                <div class="flex items-center justify-between pl-3">
                  <span class="text-[10px] font-semibold tracking-widest uppercase text-slate-400 dark:text-slate-500">
                    {t('echart.risktrade')}
                  </span>
                  <Icon name="tabler:shield-half" class="w-3.5 h-3.5 text-amber-300 dark:text-amber-400/60" />
                </div>
                <span class="text-lg font-bold tabular-nums leading-none pl-3 text-amber-500 dark:text-amber-300">
                  {riskPerTrade}
                </span>
              </div>
            )}
          </div>

          <!-- Divider Equity -->
          <div class="flex items-center gap-3 px-5 py-1.5">
            <div class="flex-1 h-px bg-slate-100 dark:echart-divider-line" />
            <span class="text-[9px] font-bold tracking-[0.15em] uppercase shrink-0
              text-slate-400 dark:echart-label-gradient">
              {t('echart.equity')}
            </span>
            <div class="flex-1 h-px bg-slate-100 dark:echart-divider-line" />
          </div>
        </>
      )}

      <!-- ── Chart ── -->
      <div class="p-4 md:p-5 bg-slate-50/50 dark:bg-slate-950/40">
        {baseOptions ? (
          <div id={chartId} data-json-id={dataId}
            class="w-full overflow-hidden rounded-lg"
            style={`height:${height};`} />
        ) : (
          <div class="flex items-center justify-center h-64 rounded-lg text-sm
            text-slate-400 dark:text-slate-600
            bg-slate-100 dark:bg-slate-900/40
            border border-dashed border-slate-200 dark:border-slate-800">
            {t('echart.noData')}
          </div>
        )}
      </div>

      <!-- ── Stats ── -->
      {showStats && stats && (
        <>
          <!-- Divider Stats -->
          <div class="flex items-center gap-3 px-5 py-1.5">
            <div class="flex-1 h-px bg-slate-100 dark:echart-divider-line" />
            <span class="text-[9px] font-bold tracking-[0.15em] uppercase shrink-0
              text-slate-400 dark:echart-label-gradient">
              {t('echart.statistics')}
            </span>
            <div class="flex-1 h-px bg-slate-100 dark:echart-divider-line" />
          </div>

          <div class="flex flex-wrap gap-px bg-slate-100 dark:bg-slate-800/60">
            {[
              { label: t('echart.totalTrades'),  value: String(stats.totalTrades),              icon: 'tabler:list-numbers',     color: 'neutral' },
              { label: t('echart.winRate'),      value: fmtPct(stats.winRate),                  icon: 'tabler:target',           color: stats.winRate >= 0.5 ? 'green' : 'red' },
              { label: t('echart.profitFactor'), value: fmtNum(stats.profitFactor),             icon: 'tabler:trending-up',      color: stats.profitFactor >= 1.5 ? 'green' : stats.profitFactor >= 1 ? 'amber' : 'red' },
              { label: t('echart.netProfit'),    value: fmtCurrency(stats.netProfit),           icon: 'tabler:cash',             color: stats.netProfit > 0 ? 'green' : 'red' },
              { label: t('echart.maxDrawdown'),  value: fmtCurrency(stats.maxDrawdown),         icon: 'tabler:arrow-down-right', color: 'red' },
              { label: t('echart.avgWin'),       value: fmtCurrency(stats.avgWin),              icon: 'tabler:plus',             color: 'green' },
              { label: t('echart.avgLoss'),      value: fmtCurrency(stats.avgLoss),             icon: 'tabler:minus',            color: 'red' },
              { label: t('echart.bestTrade'),    value: fmtCurrency(stats.bestTrade),           icon: 'tabler:star',             color: 'green' },
              { label: t('echart.worstTrade'),   value: fmtCurrency(stats.worstTrade),          icon: 'tabler:flame-off',        color: 'red' },
              { label: t('echart.expectancy'),   value: fmtCurrency(stats.expectancy),          icon: 'tabler:calculator',       color: stats.expectancy > 0 ? 'green' : 'red' },
            ].map(({ label, value, icon: i, color }) => (
              <div class:list={[
                'echart-stat relative flex flex-col justify-between gap-3 px-4 py-3.5 overflow-hidden',
                'bg-white dark:bg-slate-950/90',
                'flex-grow basis-[calc(50%-1px)] sm:basis-[calc(33.333%-1px)] lg:basis-[calc(20%-1px)]',
                'transition-all duration-200 hover:-translate-y-px',
                color === 'green'   && 'hover:dark:bg-emerald-950/40',
                color === 'red'     && 'hover:dark:bg-red-950/40',
                color === 'amber'   && 'hover:dark:bg-amber-950/30',
                color === 'neutral' && 'hover:dark:bg-primary-950/40',
              ]}>
                <!-- Accent bar with dark-mode glow -->
                <div class:list={[
                  'absolute left-0 top-3 bottom-3 w-0.5 rounded-full',
                  color === 'green'   && 'bg-emerald-500 dark:shadow-[0_0_8px_theme(colors.emerald.500/60)]',
                  color === 'red'     && 'bg-red-500     dark:shadow-[0_0_8px_theme(colors.red.500/60)]',
                  color === 'amber'   && 'bg-amber-400   dark:shadow-[0_0_8px_theme(colors.amber.400/60)]',
                  color === 'neutral' && 'bg-primary-400 dark:shadow-[0_0_6px_theme(colors.primary.500/50)]',
                ]} />

                <div class="flex items-center justify-between pl-3">
                  <span class="text-[10px] font-semibold tracking-widest uppercase text-slate-400 dark:text-slate-500">
                    {label}
                  </span>
                  <Icon name={i} class:list={[
                    'w-3.5 h-3.5 opacity-40',
                    color === 'green'   && 'text-emerald-500 dark:text-emerald-400',
                    color === 'red'     && 'text-red-500     dark:text-red-400',
                    color === 'amber'   && 'text-amber-400   dark:text-amber-300',
                    color === 'neutral' && 'text-primary-400 dark:text-primary-500',
                  ]} />
                </div>

                <span class:list={[
                  'text-lg font-bold tabular-nums leading-none pl-3',
                  color === 'green'   && 'text-emerald-600 dark:text-emerald-400',
                  color === 'red'     && 'text-red-500     dark:text-red-400',
                  color === 'amber'   && 'text-amber-500   dark:text-amber-300',
                  color === 'neutral' && 'text-slate-800   dark:text-slate-100',
                ]}>
                  {value}
                </span>
              </div>
            ))}
          </div>
        </>
      )}

    </div>{/* /z-10 content */}
  </div>{/* /inner card */}
</div>{/* /glow shell */}


  {callToAction && (
    <div class="flex justify-center mx-auto w-fit mt-8 md:mt-12 font-medium">
      <Button {...callToAction} />
    </div>
  )}
</WidgetWrapper>

{baseOptions && (
  <script type="application/json" id={dataId} set:html={JSON.stringify({ baseOptions, userOptions, locale })} />
)}

<style>
  /* Animations */
  @keyframes echart-border-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.6; }
  }
  @keyframes echart-blob-a {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%       { transform: translate(5%, 8%) scale(1.12); }
  }
  @keyframes echart-blob-b {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%       { transform: translate(-8%, -5%) scale(1.08); }
  }
  @keyframes echart-dot-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.5; }
  }

  .echart-shell         { animation: echart-border-pulse 4s ease-in-out infinite; }
  .echart-blob-a        { animation: echart-blob-a 8s ease-in-out infinite; }
  .echart-blob-b        { animation: echart-blob-b 10s ease-in-out infinite; }
  .echart-dot           { animation: echart-dot-pulse 2s ease-in-out infinite; }

  /* Gradient divider line — nur dark mode, kein JIT-Problem */
  .dark .echart-divider-line {
    background: linear-gradient(90deg, transparent, rgb(1 97 239 / 0.35), rgb(109 40 217 / 0.35), transparent);
  }

  /* Gradient text label — nur dark mode */
  .dark .echart-label-gradient {
    background: linear-gradient(90deg, #0161EF, #6D28D9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
<script>
  import { initChartWidget, cleanup } from '~/lib/chart-widget';

  document.addEventListener('astro:page-load', initChartWidget);
  document.addEventListener('astro:before-swap', cleanup);

  // Nur initialisieren wenn keine View Transitions aktiv sind,
  // da astro:page-load sonst doppelt feuert
  if (!document.startViewTransition && document.readyState !== 'loading') {
    initChartWidget();
  }
</script>
