---
// src/components/widgets/EChart.astro
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Button from '~/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
import { parseCsvData, getBaseChartOptions, calculateTradeStats } from '~/lib/chart-data';
import { useTranslations } from '~/i18n/utils';

export interface Props {
  title?: string;
  subtitle?: string;
  tagline?: string;
  icon?: string;
  csvPath?: string;
  initialCapital?: number;
  callToAction?: Record<string, any>;
  symbol?: string;
  riskPerTrade?: string;
  showStats?: boolean;
  options?: Record<string, any>;
  id?: string;
  height?: string | number;
  locale?: string;
  isDark?: boolean;
  isAfterContent?: boolean;
  classes?: { container?: string };
  bg?: string;
}

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  icon = 'tabler:info-square',
  callToAction,
  symbol,
  riskPerTrade,
  showStats = true,
  options: userOptions = {},
  initialCapital = 300,
  csvPath,
  height = '350px',
  isAfterContent = false,
  id,
  locale = Astro.currentLocale || 'de',
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

// Eindeutige IDs für Wrapper + Chart + JSON
const uid = crypto.randomUUID().slice(0, 7);
const wrapperId = id ?? `widget-${uid}`;
const chartId = `chart-${uid}`;
const dataId = `data-${uid}`;

const { lang } = Astro.params;
const t = useTranslations(lang);

// Server Side Parsing
const parsedData  = await parseCsvData(csvPath, initialCapital);
const baseOptions = getBaseChartOptions(parsedData);
const stats       = calculateTradeStats(parsedData?.trades ?? null); // ← neu

const fmtCurrency = (n) =>
  new Intl.NumberFormat(locale, { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(n);
const fmtPct = (n) => `${(n * 100).toFixed(1)} %`;
const fmtNum = (n) => (Number.isFinite(n) ? n.toFixed(2) : '∞');

const dateFrom = parsedData?.trades?.at(0)?.timestamp  ?? null;
const dateTo   = parsedData?.trades?.at(-1)?.timestamp ?? null;
const fmtDate  = (d) => d ? new Intl.DateTimeFormat(locale, { month: 'short', year: 'numeric' }).format(new Date(d)) : '—';
---

<WidgetWrapper
  id={wrapperId}
  isDark={isDark}
  containerClass={`max-w-6xl mx-auto ${isAfterContent ? 'pt-0 md:pt-0 lg:pt-0' : ''} ${classes?.container ?? ''}`}
  bg={bg}
>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />

<!-- Unified container: jetzt mit YouTube-Stil -->
<div class="relative rounded-xl overflow-hidden shadow-xl border border-white/10">

  <!-- Dark gradient background (always-on, wie YouTube) -->
  <div class="absolute inset-0 bg-gradient-to-br from-slate-800 to-slate-950" />

  <!-- Dot pattern overlay -->
  <div
    class="absolute inset-0 opacity-[0.06] pointer-events-none"
    style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 24px 24px;"
  />

  <!-- Gesamter Inhalt muss relative sein, um über den absoluten Layern zu liegen -->
  <div class="relative">

    <!-- Symbol / Config Header -->
    {(symbol || riskPerTrade) && (
      <>
        <div class="flex flex-wrap gap-px bg-white/5">

          {symbol && (
            <div class="relative flex flex-col justify-between gap-3 px-4 py-3 bg-slate-900/60 backdrop-blur-sm
                  flex-grow basis-[calc(50%-1px)] sm:basis-[calc(33.333%-1px)] lg:basis-[calc(20%-1px)]">
              <div class="absolute left-0 top-3 bottom-3 w-[2px] rounded-full bg-white/20" />
              <div class="flex items-center justify-between pl-3">
                <span class="text-[11px] font-medium leading-none tracking-wide text-white/40">
                  {t('echart.symbol')}
                </span>
                <Icon name="tabler:currency-bitcoin" class="w-3.5 h-3.5 shrink-0 opacity-30 text-white" />
              </div>
              <span class="text-lg font-bold tabular-nums leading-none pl-3 text-white/90">
                {symbol}
              </span>
            </div>
          )}

          {(dateFrom && dateTo) && (
            <div class="relative flex flex-col justify-between gap-3 px-4 py-3 bg-slate-900/60 backdrop-blur-sm
                  flex-grow basis-[calc(50%-1px)] sm:basis-[calc(33.333%-1px)] lg:basis-[calc(40%-1px)]">
              <div class="absolute left-0 top-3 bottom-3 w-[2px] rounded-full bg-white/20" />
              <div class="flex items-center justify-between pl-3">
                <span class="text-[11px] font-medium leading-none tracking-wide text-white/40">
                  {t('echart.period')}
                </span>
                <Icon name="tabler:calendar-stats" class="w-3.5 h-3.5 shrink-0 opacity-30 text-white" />
              </div>
              <span class="text-lg font-bold tabular-nums leading-none pl-3 text-white/90">
                {fmtDate(dateFrom)} – {fmtDate(dateTo)}
              </span>
            </div>
          )}

          {initialCapital && (
            <div class="relative flex flex-col justify-between gap-3 px-4 py-3 bg-slate-900/60 backdrop-blur-sm
                  flex-grow basis-[calc(50%-1px)] sm:basis-[calc(33.333%-1px)] lg:basis-[calc(20%-1px)]">
              <div class="absolute left-0 top-3 bottom-3 w-[2px] rounded-full bg-white/20" />
              <div class="flex items-center justify-between pl-3">
                <span class="text-[11px] font-medium leading-none tracking-wide text-white/40">
                  {t('echart.initialCapital')}
                </span>
                <Icon name="tabler:wallet" class="w-3.5 h-3.5 shrink-0 opacity-30 text-white" />
              </div>
              <span class="text-lg font-bold tabular-nums leading-none pl-3 text-white/90">
                {fmtCurrency(initialCapital)}
              </span>
            </div>
          )}

          {riskPerTrade && (
            <div class="relative flex flex-col justify-between gap-3 px-4 py-3 bg-slate-900/60 backdrop-blur-sm
                  flex-grow basis-[calc(50%-1px)] sm:basis-[calc(33.333%-1px)] lg:basis-[calc(20%-1px)]">
              <div class="absolute left-0 top-3 bottom-3 w-[2px] rounded-full bg-amber-400" />
              <div class="flex items-center justify-between pl-3">
                <span class="text-[11px] font-medium leading-none tracking-wide text-white/40">
                  {t('echart.risktrade')}
                </span>
                <Icon name="tabler:shield-half" class="w-3.5 h-3.5 shrink-0 opacity-40 text-amber-300" />
              </div>
              <span class="text-lg font-bold tabular-nums leading-none pl-3 text-amber-300">
                {riskPerTrade}
              </span>
            </div>
          )}

        </div>

        <!-- Trennlinie Chart -->
        <div class="flex items-center gap-3 px-4 md:px-6">
          <div class="flex-1 h-px bg-white/10" />
          <span class="text-[10px] font-semibold uppercase tracking-widest text-white/20 shrink-0">
            {t('echart.equity')}
          </span>
          <div class="flex-1 h-px bg-white/10" />
        </div>
      </>
    )}

    <!-- Chart -->
    <div class="p-4 md:p-6">
      {baseOptions ? (
        <div
          id={chartId}
          data-json-id={dataId}
          class="w-full overflow-hidden"
          style={`height:${height};`}
        ></div>
      ) : (
        <div class="flex items-center justify-center h-64 text-white/30 bg-white/5 rounded border border-dashed border-white/10">
          <span class="text-sm">{t('echart.noData')}</span>
        </div>
      )}
    </div>

    {showStats && stats && (
      <>
        <div class="flex items-center gap-3 px-4 md:px-6">
          <div class="flex-1 h-px bg-white/10" />
          <span class="text-[10px] font-semibold uppercase tracking-widest text-white/20 shrink-0">
            {t('echart.statistics')}
          </span>
          <div class="flex-1 h-px bg-white/10" />
        </div>

        <div class="flex flex-wrap gap-px bg-white/5">
          {[
            { label: t('echart.totalTrades'),  value: String(stats.totalTrades),              icon: 'tabler:list-numbers',     color: 'neutral' },
            { label: t('echart.winRate'),      value: fmtPct(stats.winRate),                  icon: 'tabler:target',           color: stats.winRate >= 0.5 ? 'green' : 'red' },
            { label: t('echart.profitFactor'), value: fmtNum(stats.profitFactor),             icon: 'tabler:trending-up',      color: stats.profitFactor >= 1.5 ? 'green' : stats.profitFactor >= 1 ? 'amber' : 'red' },
            { label: t('echart.netProfit'),    value: fmtCurrency(stats.netProfit, locale),   icon: 'tabler:cash',             color: stats.netProfit > 0 ? 'green' : 'red' },
            { label: t('echart.maxDrawdown'),  value: fmtCurrency(stats.maxDrawdown, locale), icon: 'tabler:arrow-down-right', color: 'red' },
            { label: t('echart.avgWin'),       value: fmtCurrency(stats.avgWin, locale),      icon: 'tabler:plus',             color: 'green' },
            { label: t('echart.avgLoss'),      value: fmtCurrency(stats.avgLoss, locale),     icon: 'tabler:minus',            color: 'red' },
            { label: t('echart.bestTrade'),    value: fmtCurrency(stats.bestTrade, locale),   icon: 'tabler:star',             color: 'green' },
            { label: t('echart.worstTrade'),   value: fmtCurrency(stats.worstTrade, locale),  icon: 'tabler:flame-off',        color: 'red' },
            { label: t('echart.expectancy'),   value: fmtCurrency(stats.expectancy, locale),  icon: 'tabler:calculator',       color: stats.expectancy > 0 ? 'green' : 'red' },
          ].map(({ label, value, icon: i, color }) => (
            <div class="relative flex flex-col justify-between gap-3 px-4 py-3 overflow-hidden bg-slate-900/60 backdrop-blur-sm
                  flex-grow basis-[calc(50%-1px)] sm:basis-[calc(33.333%-1px)] lg:basis-[calc(20%-1px)]">
              <div class:list={[
                'absolute left-0 top-3 bottom-3 w-[2px] rounded-full',
                color === 'green'   && 'bg-emerald-400',
                color === 'red'     && 'bg-red-400',
                color === 'amber'   && 'bg-amber-300',
                color === 'neutral' && 'bg-white/20',
              ]} />
              <div class="flex items-center justify-between pl-3">
                <span class="text-[11px] font-medium leading-none tracking-wide text-white/40">
                  {label}
                </span>
                <Icon name={i} class:list={[
                  'w-3.5 h-3.5 shrink-0 opacity-40',
                  color === 'green'   && 'text-emerald-400',
                  color === 'red'     && 'text-red-400',
                  color === 'amber'   && 'text-amber-300',
                  color === 'neutral' && 'text-white',
                ]} />
              </div>
              <span class:list={[
                'text-lg font-bold tabular-nums leading-none pl-3',
                color === 'green'   && 'text-emerald-400',
                color === 'red'     && 'text-red-400',
                color === 'amber'   && 'text-amber-300',
                color === 'neutral' && 'text-white/90',
              ]}>
                {value}
              </span>
            </div>
          ))}
        </div>
      </>
    )}

  </div>{/* /relative content wrapper */}
</div>{/* /main container */}


  {callToAction && (
    <div class="flex justify-center mx-auto w-fit mt-8 md:mt-12 font-medium">
      <Button {...callToAction} />
    </div>
  )}
</WidgetWrapper>

{baseOptions && (
  <script type="application/json" id={dataId} set:html={JSON.stringify({ baseOptions, userOptions, locale })} />
)}

<script>
  import { initChartWidget, cleanup } from '~/lib/chart-widget';

  document.addEventListener('astro:page-load', initChartWidget);
  document.addEventListener('astro:before-swap', cleanup);

  // Nur initialisieren wenn keine View Transitions aktiv sind,
  // da astro:page-load sonst doppelt feuert
  if (!document.startViewTransition && document.readyState !== 'loading') {
    initChartWidget();
  }
</script>
