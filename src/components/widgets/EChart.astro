---
// src/components/widgets/EChart.astro
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Button from '~/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
import { parseCsvData, getBaseChartOptions, calculateTradeStats } from '~/lib/chart-data';

export interface Props {
  title?: string;
  subtitle?: string;
  tagline?: string;
  icon?: string;
  csvPath?: string;
  initialCapital?: number;
  callToAction?: Record<string, any>;
  content?: string;
  options?: Record<string, any>;
  id?: string;
  height?: string | number;
  locale?: string;
  isDark?: boolean;
  isAfterContent?: boolean;
  classes?: { container?: string };
  bg?: string;
}

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  icon = 'tabler:info-square',
  callToAction,
  content = await Astro.slots.render('content'),
  options: userOptions = {},
  initialCapital = 300,
  csvPath,
  height = '450px',
  isAfterContent = false,
  id,
  locale = Astro.currentLocale || 'de',
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

// Eindeutige IDs für Wrapper + Chart + JSON
const uid = crypto.randomUUID().slice(0, 7);
const wrapperId = id ?? `widget-${uid}`;
const chartId = `chart-${uid}`;
const dataId = `data-${uid}`;

// Server Side Parsing
const parsedData  = await parseCsvData(csvPath, initialCapital);
const baseOptions = getBaseChartOptions(parsedData);
const stats       = calculateTradeStats(parsedData?.trades ?? null); // ← neu

const fmtCurrency = (n) =>
  new Intl.NumberFormat(locale, { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(n);
const fmtPct = (n) => `${(n * 100).toFixed(1)} %`;
const fmtNum = (n) => (Number.isFinite(n) ? n.toFixed(2) : '∞');
---

<WidgetWrapper
  id={wrapperId}
  isDark={isDark}
  containerClass={`max-w-6xl mx-auto ${isAfterContent ? 'pt-0 md:pt-0 lg:pt-0' : ''} ${classes?.container ?? ''}`}
  bg={bg}
>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />

  {content && (
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 text-md text-center font-medium">
      <Icon name={icon} class="w-5 h-5 inline-block align-text-bottom font-bold" />
      <Fragment set:html={content} />
    </div>
  )}

  <div class="p-4 md:p-6 rounded-md shadow-xl dark:border dark:border-slate-600 bg-white dark:bg-slate-900">
    {baseOptions ? (
      <div
        id={chartId}
        data-json-id={dataId}
        class="w-full overflow-hidden"
        style={`height:${height};`}
      ></div>
    ) : (
      <div class="flex items-center justify-center h-64 text-slate-400 bg-slate-50 dark:bg-slate-800/50 rounded border border-dashed border-slate-300 dark:border-slate-700">
        <span class="text-sm">Keine Daten verfügbar.</span>
      </div>
    )}
  </div>

{stats && (
  <div class="mt-6">
    <!-- Section Header -->
    <div class="flex items-center gap-3 mb-4 px-1">
      <h3 class="text-sm font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500">
        {locale === 'de' ? 'Performance-Statistiken' : 'Performance Statistics'}
      </h3>
      <div class="flex-1 h-px bg-slate-200 dark:bg-slate-700" />
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
      {[
        { label: locale === 'de' ? 'Trades gesamt'  : 'Total Trades',  value: String(stats.totalTrades),      icon: 'tabler:list-numbers',   color: 'neutral' },
        { label: locale === 'de' ? 'Trefferquote'   : 'Win Rate',       value: fmtPct(stats.winRate),          icon: 'tabler:target',         color: stats.winRate >= 0.5 ? 'green' : 'red' },
        { label: 'Profit Factor',                                        value: fmtNum(stats.profitFactor),     icon: 'tabler:trending-up',    color: stats.profitFactor >= 1.5 ? 'green' : stats.profitFactor >= 1 ? 'amber' : 'red' },
        { label: locale === 'de' ? 'Nettogewinn'    : 'Net Profit',     value: fmtCurrency(stats.netProfit, locale),   icon: 'tabler:cash',           color: stats.netProfit > 0 ? 'green' : 'red' },
        { label: locale === 'de' ? 'Max. Drawdown'  : 'Max Drawdown',   value: fmtCurrency(stats.maxDrawdown, locale), icon: 'tabler:arrow-down-right', color: 'red' },
        { label: locale === 'de' ? 'Ø Gewinn'       : 'Avg Win',        value: fmtCurrency(stats.avgWin, locale),      icon: 'tabler:plus',           color: 'green' },
        { label: locale === 'de' ? 'Ø Verlust'      : 'Avg Loss',       value: fmtCurrency(stats.avgLoss, locale),     icon: 'tabler:minus',          color: 'red' },
        { label: locale === 'de' ? 'Bester Trade'   : 'Best Trade',     value: fmtCurrency(stats.bestTrade, locale),   icon: 'tabler:star',           color: 'green' },
        { label: locale === 'de' ? 'Schlechtester'  : 'Worst Trade',    value: fmtCurrency(stats.worstTrade, locale),  icon: 'tabler:flame-off',      color: 'red' },
        { label: locale === 'de' ? 'Erwartungswert' : 'Expectancy',     value: fmtCurrency(stats.expectancy, locale),  icon: 'tabler:calculator',     color: stats.expectancy > 0 ? 'green' : 'red' },
      ].map(({ label, value, icon: i, color }) => (
        <div class:list={[
          // Gleiche Card-Basis wie der Chart-Container
          'relative flex flex-col gap-2 rounded-lg px-4 py-3.5',
          'bg-white dark:bg-slate-900',
          'shadow dark:border dark:border-slate-700',
          // Farbiger Left-Border-Akzent
          'border-l-[3px]',
          color === 'green'   && 'border-l-emerald-500',
          color === 'red'     && 'border-l-red-500',
          color === 'amber'   && 'border-l-amber-400',
          color === 'neutral' && 'border-l-slate-300 dark:border-l-slate-600',
        ]}>
          <!-- Icon + Label -->
          <div class="flex items-center gap-2">
            <span class:list={[
              'inline-flex items-center justify-center w-6 h-6 rounded-md shrink-0',
              color === 'green'   && 'bg-emerald-50  dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400',
              color === 'red'     && 'bg-red-50     dark:bg-red-900/30     text-red-500     dark:text-red-400',
              color === 'amber'   && 'bg-amber-50   dark:bg-amber-900/30   text-amber-600   dark:text-amber-400',
              color === 'neutral' && 'bg-slate-100  dark:bg-slate-800      text-slate-400   dark:text-slate-500',
            ]}>
              <Icon name={i} class="w-3.5 h-3.5" />
            </span>
            <span class="text-[11px] font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500 leading-tight">
              {label}
            </span>
          </div>

          <!-- Wert -->
          <span class:list={[
            'text-xl font-bold tabular-nums leading-none pl-0.5',
            color === 'green'   && 'text-emerald-600 dark:text-emerald-400',
            color === 'red'     && 'text-red-500     dark:text-red-400',
            color === 'amber'   && 'text-amber-500   dark:text-amber-400',
            color === 'neutral' && 'text-slate-900   dark:text-slate-100',
          ]}>
            {value}
          </span>
        </div>
      ))}
    </div>
  </div>
)}

  {callToAction && (
    <div class="flex justify-center mx-auto w-fit mt-8 md:mt-12 font-medium">
      <Button {...callToAction} />
    </div>
  )}
</WidgetWrapper>

{baseOptions && (
  <script type="application/json" id={dataId} set:html={JSON.stringify({ baseOptions, userOptions, locale })} />
)}

<script>
  import { initChartWidget, cleanup } from '~/lib/chart-widget';

  document.addEventListener('astro:page-load', initChartWidget);
  document.addEventListener('astro:before-swap', cleanup);

  // Nur initialisieren wenn keine View Transitions aktiv sind,
  // da astro:page-load sonst doppelt feuert
  if (!document.startViewTransition && document.readyState !== 'loading') {
    initChartWidget();
  }
</script>
