---
// src/components/widgets/EChart.astro
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Button from '~/components/ui/Button.astro';
import { Icon } from 'astro-icon/components';
import { parseCsvData, getBaseChartOptions, calculateTradeStats } from '~/lib/chart-data';
import { useTranslations } from '~/i18n/utils';

export interface Props {
  title?: string;
  subtitle?: string;
  tagline?: string;
  icon?: string;
  csvPath?: string;
  initialCapital?: number;
  callToAction?: Record<string, any>;
  symbol?: string;
  riskPerTrade?: string;
  showStats?: boolean;
  options?: Record<string, any>;
  id?: string;
  height?: string | number;
  locale?: string;
  isDark?: boolean;
  isAfterContent?: boolean;
  classes?: { container?: string };
  bg?: string;
}

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  icon = 'tabler:info-square',
  callToAction,
  symbol,
  riskPerTrade,
  showStats = true,
  options: userOptions = {},
  initialCapital = 300,
  csvPath,
  height = '350px',
  isAfterContent = false,
  id,
  locale = Astro.currentLocale || 'de',
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;

// Eindeutige IDs für Wrapper + Chart + JSON
const uid = crypto.randomUUID().slice(0, 7);
const wrapperId = id ?? `widget-${uid}`;
const chartId = `chart-${uid}`;
const dataId = `data-${uid}`;

const { lang } = Astro.params;
const t = useTranslations(lang);

// Server Side Parsing
const parsedData  = await parseCsvData(csvPath, initialCapital);
const baseOptions = getBaseChartOptions(parsedData);
const stats       = calculateTradeStats(parsedData?.trades ?? null); // ← neu

const fmtCurrency = (n) =>
  new Intl.NumberFormat(locale, { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(n);
const fmtPct = (n) => `${(n * 100).toFixed(1)} %`;
const fmtNum = (n) => (Number.isFinite(n) ? n.toFixed(2) : '∞');

const dateFrom = parsedData?.trades?.at(0)?.timestamp  ?? null;
const dateTo   = parsedData?.trades?.at(-1)?.timestamp ?? null;
const fmtDate  = (d) => d ? new Intl.DateTimeFormat(locale, { month: 'short', year: 'numeric' }).format(new Date(d)) : '—';
---

<WidgetWrapper
  id={wrapperId}
  isDark={isDark}
  containerClass={`max-w-6xl mx-auto ${isAfterContent ? 'pt-0 md:pt-0 lg:pt-0' : ''} ${classes?.container ?? ''}`}
  bg={bg}
>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />

<!-- ── Outer glow shell ── -->
<div class="relative rounded-2xl p-px"
  style="background: linear-gradient(135deg, #0161EF44, #6D28D988, #0161EF44);
         box-shadow: 0 0 0 1px #0161EF33, 0 0 60px #0161EF1a, 0 0 120px #6D28D90d, 0 32px 64px #00000066;
         animation: borderPulse 4s ease-in-out infinite;">

  <div class="relative rounded-2xl overflow-hidden" style="background: #030620;">

    <!-- Aurora blobs -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute rounded-full opacity-[0.18]"
        style="width:60%;height:60%;top:-20%;left:-10%;background:#0161EF;filter:blur(80px);animation:blobA 8s ease-in-out infinite;" />
      <div class="absolute rounded-full opacity-[0.15]"
        style="width:50%;height:50%;bottom:-20%;right:-10%;background:#6D28D9;filter:blur(80px);animation:blobB 10s ease-in-out infinite;" />
      <div class="absolute rounded-full opacity-[0.07]"
        style="width:30%;height:30%;top:30%;left:40%;background:#00C896;filter:blur(60px);animation:blobA 12s ease-in-out infinite reverse;" />
    </div>

    <!-- Dot grid -->
    <div class="absolute inset-0 z-0 pointer-events-none opacity-[0.07]"
      style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 24px 24px;" />

    <!-- All content sits above layers -->
    <div class="relative z-10">

      <!-- Header bar -->
      <div class="flex items-center gap-2.5 px-5 py-3.5 border-b"
        style="border-color: rgba(255,255,255,0.05);">
        <div class="w-2 h-2 rounded-full shrink-0"
          style="background: linear-gradient(135deg,#0161EF,#6D28D9); box-shadow: 0 0 10px #0161EFaa; animation: dotPulse 2s ease-in-out infinite;" />
        <span class="text-[11px] font-bold tracking-[0.12em] uppercase"
          style="background:linear-gradient(90deg,rgba(255,255,255,0.85),rgba(255,255,255,0.4));-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
          AmendLogic · Performance
        </span>
        <span class="ml-auto text-[9px] font-bold tracking-[0.1em] uppercase px-2.5 py-1 rounded-full"
          style="background:linear-gradient(135deg,rgba(1,97,239,0.15),rgba(109,40,217,0.15));border:1px solid rgba(1,97,239,0.3);color:rgba(1,97,239,0.9);">
          Backtest
        </span>
      </div>

      <!-- Config cells -->
      {(symbol || riskPerTrade) && (
        <div class="flex flex-wrap" style="gap:1px;background:rgba(255,255,255,0.06);">

          {symbol && (
            <div class="relative flex flex-col justify-between gap-3 px-4 py-3.5 overflow-hidden
                  flex-grow basis-[calc(50%-1px)] sm:basis-[calc(33.333%-1px)] lg:basis-[calc(20%-1px)]"
              style="background:rgba(3,6,32,0.85);">
              <div class="absolute left-0 top-3 bottom-3 w-0.5 rounded-full"
                style="background:linear-gradient(180deg,#0161EF,#6D28D9);box-shadow:0 0 6px #0161EF88;" />
              <div class="flex items-center justify-between pl-3">
                <span class="text-[10px] font-semibold tracking-widest uppercase" style="color:rgba(255,255,255,0.35);">
                  {t('echart.symbol')}
                </span>
                <Icon name="tabler:currency-bitcoin" class="w-3.5 h-3.5" style="color:rgba(1,97,239,0.5);" />
              </div>
              <span class="text-lg font-bold tabular-nums leading-none pl-3" style="color:rgba(255,255,255,0.9);">{symbol}</span>
            </div>
          )}

          {(dateFrom && dateTo) && (
            <div class="relative flex flex-col justify-between gap-3 px-4 py-3.5 overflow-hidden
                  flex-grow basis-[calc(50%-1px)] sm:basis-[calc(33.333%-1px)] lg:basis-[calc(40%-1px)]"
              style="background:rgba(3,6,32,0.85);">
              <div class="absolute left-0 top-3 bottom-3 w-0.5 rounded-full"
                style="background:linear-gradient(180deg,#0161EF,#6D28D9);box-shadow:0 0 6px #0161EF88;" />
              <div class="flex items-center justify-between pl-3">
                <span class="text-[10px] font-semibold tracking-widest uppercase" style="color:rgba(255,255,255,0.35);">
                  {t('echart.period')}
                </span>
                <Icon name="tabler:calendar-stats" class="w-3.5 h-3.5" style="color:rgba(1,97,239,0.5);" />
              </div>
              <span class="text-lg font-bold tabular-nums leading-none pl-3" style="color:rgba(255,255,255,0.9);">
                {fmtDate(dateFrom)} – {fmtDate(dateTo)}
              </span>
            </div>
          )}

          {initialCapital && (
            <div class="relative flex flex-col justify-between gap-3 px-4 py-3.5 overflow-hidden
                  flex-grow basis-[calc(50%-1px)] sm:basis-[calc(33.333%-1px)] lg:basis-[calc(20%-1px)]"
              style="background:rgba(3,6,32,0.85);">
              <div class="absolute left-0 top-3 bottom-3 w-0.5 rounded-full"
                style="background:linear-gradient(180deg,#0161EF,#6D28D9);box-shadow:0 0 6px #0161EF88;" />
              <div class="flex items-center justify-between pl-3">
                <span class="text-[10px] font-semibold tracking-widest uppercase" style="color:rgba(255,255,255,0.35);">
                  {t('echart.initialCapital')}
                </span>
                <Icon name="tabler:wallet" class="w-3.5 h-3.5" style="color:rgba(1,97,239,0.5);" />
              </div>
              <span class="text-lg font-bold tabular-nums leading-none pl-3" style="color:rgba(255,255,255,0.9);">
                {fmtCurrency(initialCapital)}
              </span>
            </div>
          )}

          {riskPerTrade && (
            <div class="relative flex flex-col justify-between gap-3 px-4 py-3.5 overflow-hidden
                  flex-grow basis-[calc(50%-1px)] sm:basis-[calc(33.333%-1px)] lg:basis-[calc(20%-1px)]"
              style="background:rgba(3,6,32,0.85);">
              <div class="absolute left-0 top-3 bottom-3 w-0.5 rounded-full"
                style="background:#FBBF24;box-shadow:0 0 8px #FBBF2488;" />
              <div class="flex items-center justify-between pl-3">
                <span class="text-[10px] font-semibold tracking-widest uppercase" style="color:rgba(255,255,255,0.35);">
                  {t('echart.risktrade')}
                </span>
                <Icon name="tabler:shield-half" class="w-3.5 h-3.5" style="color:rgba(251,191,36,0.6);" />
              </div>
              <span class="text-lg font-bold tabular-nums leading-none pl-3" style="color:#FBBF24;">{riskPerTrade}</span>
            </div>
          )}

        </div>
      )}

      <!-- Divider: Equity -->
      <div class="flex items-center gap-3 px-5 py-1.5">
        <div class="flex-1 h-px" style="background:linear-gradient(90deg,transparent,#0161EF55,#6D28D955,transparent);" />
        <span class="text-[9px] font-bold tracking-[0.15em] uppercase shrink-0"
          style="background:linear-gradient(90deg,#0161EF,#6D28D9);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
          {t('echart.equity')}
        </span>
        <div class="flex-1 h-px" style="background:linear-gradient(90deg,transparent,#6D28D955,#0161EF55,transparent);" />
      </div>

      <!-- Chart -->
      <div class="p-4 md:p-5" style="background:rgba(1,6,32,0.4);">
        {baseOptions ? (
          <div id={chartId} data-json-id={dataId} class="w-full overflow-hidden rounded-lg" style={`height:${height};`} />
        ) : (
          <div class="flex items-center justify-center h-64 rounded-lg text-sm"
            style="background:rgba(255,255,255,0.03);border:1px dashed rgba(255,255,255,0.1);color:rgba(255,255,255,0.2);">
            {t('echart.noData')}
          </div>
        )}
      </div>

      {showStats && stats && (
        <>
          <!-- Divider: Stats -->
          <div class="flex items-center gap-3 px-5 py-1.5">
            <div class="flex-1 h-px" style="background:linear-gradient(90deg,transparent,#0161EF55,#6D28D955,transparent);" />
            <span class="text-[9px] font-bold tracking-[0.15em] uppercase shrink-0"
              style="background:linear-gradient(90deg,#0161EF,#6D28D9);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
              {t('echart.statistics')}
            </span>
            <div class="flex-1 h-px" style="background:linear-gradient(90deg,transparent,#6D28D955,#0161EF55,transparent);" />
          </div>

          <div class="flex flex-wrap" style="gap:1px;background:rgba(255,255,255,0.06);">
            {[
              { label: t('echart.totalTrades'),  value: String(stats.totalTrades),              icon: 'tabler:list-numbers',     color: 'neutral' },
              { label: t('echart.winRate'),      value: fmtPct(stats.winRate),                  icon: 'tabler:target',           color: stats.winRate >= 0.5 ? 'green' : 'red' },
              { label: t('echart.profitFactor'), value: fmtNum(stats.profitFactor),             icon: 'tabler:trending-up',      color: stats.profitFactor >= 1.5 ? 'green' : stats.profitFactor >= 1 ? 'amber' : 'red' },
              { label: t('echart.netProfit'),    value: fmtCurrency(stats.netProfit, locale),   icon: 'tabler:cash',             color: stats.netProfit > 0 ? 'green' : 'red' },
              { label: t('echart.maxDrawdown'),  value: fmtCurrency(stats.maxDrawdown, locale), icon: 'tabler:arrow-down-right', color: 'red' },
              { label: t('echart.avgWin'),       value: fmtCurrency(stats.avgWin, locale),      icon: 'tabler:plus',             color: 'green' },
              { label: t('echart.avgLoss'),      value: fmtCurrency(stats.avgLoss, locale),     icon: 'tabler:minus',            color: 'red' },
              { label: t('echart.bestTrade'),    value: fmtCurrency(stats.bestTrade, locale),   icon: 'tabler:star',             color: 'green' },
              { label: t('echart.worstTrade'),   value: fmtCurrency(stats.worstTrade, locale),  icon: 'tabler:flame-off',        color: 'red' },
              { label: t('echart.expectancy'),   value: fmtCurrency(stats.expectancy, locale),  icon: 'tabler:calculator',       color: stats.expectancy > 0 ? 'green' : 'red' },
            ].map(({ label, value, icon: i, color }) => {
              const barStyle = {
                green:   'background:#00C896;box-shadow:0 0 8px #00C89666;',
                red:     'background:#EF4444;box-shadow:0 0 8px #EF444466;',
                amber:   'background:#FBBF24;box-shadow:0 0 8px #FBBF2466;',
                neutral: 'background:linear-gradient(180deg,#0161EF,#6D28D9);box-shadow:0 0 6px #0161EF55;',
              }[color];
              const valStyle = {
                green: 'color:#00C896;', red: 'color:#F87171;',
                amber: 'color:#FBBF24;', neutral: 'color:rgba(255,255,255,0.9);',
              }[color];
              const glowStyle = {
                green:   'background:radial-gradient(ellipse at bottom left,rgba(0,200,150,0.12),transparent 70%)',
                red:     'background:radial-gradient(ellipse at bottom left,rgba(239,68,68,0.12),transparent 70%)',
                amber:   'background:radial-gradient(ellipse at bottom left,rgba(251,191,36,0.12),transparent 70%)',
                neutral: 'background:radial-gradient(ellipse at bottom left,rgba(1,97,239,0.1),transparent 70%)',
              }[color];
              return (
                <div class="stat-wow-cell relative flex flex-col justify-between gap-3 px-4 py-3.5 overflow-hidden
                      flex-grow basis-[calc(50%-1px)] sm:basis-[calc(33.333%-1px)] lg:basis-[calc(20%-1px)]"
                  style="background:rgba(3,6,32,0.85);transition:all 0.25s ease;cursor:default;">
                  <!-- Hover glow layer (CSS animation via style tag below) -->
                  <div class="stat-wow-glow absolute inset-0 opacity-0 transition-opacity duration-300" style={glowStyle} />
                  <div class="absolute left-0 top-3 bottom-3 w-0.5 rounded-full" style={barStyle} />
                  <div class="flex items-center justify-between pl-3 relative">
                    <span class="text-[10px] font-semibold tracking-widest uppercase" style="color:rgba(255,255,255,0.35);">
                      {label}
                    </span>
                    <Icon name={i} class="w-3.5 h-3.5 opacity-40" style={valStyle} />
                  </div>
                  <span class="text-lg font-bold tabular-nums leading-none pl-3 relative" style={valStyle}>
                    {value}
                  </span>
                </div>
              );
            })}
          </div>
        </>
      )}

    </div>
  </div>
</div>


  {callToAction && (
    <div class="flex justify-center mx-auto w-fit mt-8 md:mt-12 font-medium">
      <Button {...callToAction} />
    </div>
  )}
</WidgetWrapper>

{baseOptions && (
  <script type="application/json" id={dataId} set:html={JSON.stringify({ baseOptions, userOptions, locale })} />
)}

<style>
  @keyframes borderPulse {
    0%, 100% { box-shadow: 0 0 0 1px #0161EF44, 0 0 60px #0161EF1a, 0 0 120px #6D28D90d, 0 32px 64px #00000066; }
    50%       { box-shadow: 0 0 0 1px #6D28D966, 0 0 80px #0161EF2a, 0 0 160px #6D28D91a, 0 32px 64px #00000066; }
  }
  @keyframes blobA {
    0%, 100% { transform: translate(0,0) scale(1); }
    50%       { transform: translate(5%,8%) scale(1.1); }
  }
  @keyframes blobB {
    0%, 100% { transform: translate(0,0) scale(1); }
    50%       { transform: translate(-8%,-5%) scale(1.08); }
  }
  @keyframes dotPulse {
    0%, 100% { box-shadow: 0 0 8px #0161EFaa; }
    50%       { box-shadow: 0 0 16px #6D28D9cc; }
  }
  .stat-wow-cell:hover { transform: translateY(-1px); }
  .stat-wow-cell:hover .stat-wow-glow { opacity: 1; }
</style>

<script>
  import { initChartWidget, cleanup } from '~/lib/chart-widget';

  document.addEventListener('astro:page-load', initChartWidget);
  document.addEventListener('astro:before-swap', cleanup);

  // Nur initialisieren wenn keine View Transitions aktiv sind,
  // da astro:page-load sonst doppelt feuert
  if (!document.startViewTransition && document.readyState !== 'loading') {
    initChartWidget();
  }
</script>
