---
import { getAsset } from '~/utils/permalinks';

// Holt die Sprache aus der URL (z.B. "de" oder "en")
const { lang } = Astro.params;

// Falls 'lang' undefiniert ist (z.B. auf der Startseite ohne Sprachkürzel), 
// kannst du einen Standard setzen.
const currentLang = lang || 'de'; 

// Erstellt den Pfad zum Feed: /de/rss.xml oder /en/rss.xml
const rssPath = `/${currentLang}/rss.xml`;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />

<link rel="sitemap" href={getAsset('/sitemap-index.xml')} />

<link 
  rel="alternate" 
  type="application/rss+xml" 
  title={`RSS Feed (${currentLang.toUpperCase()})`} 
  href={getAsset(rssPath)} 
/>
